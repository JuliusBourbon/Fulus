{
  "expo": {
    "name": "Fulus",
    "slug": "Fulus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Fulus.png",
    "scheme": "fulus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.juliusbourbon.Fulus"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Fulus.png",
          "imageWidth": 500,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b6d0df2-4946-44f3-8953-503cd7f62f25"
      }
    }
  }
}
